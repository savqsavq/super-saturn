---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Custom Iron Works of Oklahoma</title>
    <meta name="description" content="30+ years of custom ironwork, welding, gates, fences, and metal fabrication serving Oklahoma City and surrounding areas." />
    <meta property="og:title" content="Custom Iron Works of Oklahoma" />
    <meta property="og:description" content="30+ years of custom ironwork. Gates, fences, handrails, welding. Oklahoma City and surrounding areas." />
    <meta property="og:image" content="/welder_image.jpg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800&family=Barlow:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- NAV -->
    <nav>
      <div class="nav-inner">
        <div class="nav-brand">
          <span class="brand-main">Custom Iron Works</span>
          <span class="brand-sub">of Oklahoma</span>
        </div>
        <a href="tel:+14052274404" class="nav-cta">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
          (405) 227-4404
        </a>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-image-wrap">
        <img src="/welder_image.jpg" alt="Custom Iron Works welding" class="hero-img" />
        <div class="hero-overlay"></div>
      </div>
      <div class="hero-content">
        <div class="hero-badge">30+ Years of Experience · Oklahoma City</div>
        <h1 class="hero-title">
          Custom Iron Works<br />
          <span class="hero-title-sub">of Oklahoma</span>
        </h1>
        <div class="hero-actions">
          <a href="tel:+14052274404" class="hero-btn hero-btn-primary">Call Now for a Free Consultation</a>
          <a href="#contact" class="hero-btn hero-btn-secondary">Get In Touch ↓</a>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="services" id="services">
      <div class="services-inner">
        <div class="section-label">What We Do</div>
        <h2 class="section-title">Services Offered</h2>
        <div class="services-grid">
          {services.map((s) => (
            <div class="service-card">
              <div class="service-line"></div>
              <h3 class="service-name">{s.title}</h3>
              <p class="service-desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section class="contact" id="contact">
      <div class="contact-inner">
        <div class="section-label">Get In Touch</div>
        <h2 class="section-title">Expect a prompt response</h2>

        <div class="contact-grid">
          <div class="contact-block contact-block-main">
            <div class="contact-block-label">Call or Text</div>
            <a href="tel:+14052274404" class="contact-phone">(405) 227-4404</a>
            <p class="contact-note">Call or text anytime.</p>
          </div>
          <div class="contact-block">
            <div class="contact-block-label">Email</div>
            <a href="mailto:keithsummers11@gmail.com" class="contact-email">keithsummers11@gmail.com</a>
          </div>
          <div class="contact-block">
            <div class="contact-block-label">Hours</div>
            <p class="contact-hours">7 Days a Week</p>
            <p class="contact-hours">8am – 8pm</p>
          </div>
          <div class="contact-block">
            <div class="contact-block-label">Service Area</div>
            <p class="contact-area">Oklahoma City and all surrounding areas</p>
          </div>
        </div>

        <a href="tel:+14052274404" class="contact-btn">Call Now for a Free Consultation</a>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="testimonials" id="testimonials">
      <div class="testimonials-inner">
        <div class="section-label">Happy Customers</div>
        <h2 class="section-title">What People Say</h2>
        <div class="testimonials-grid">
          {testimonials.map((t) => (
            <blockquote class="testimonial-card">
              <p class="testimonial-text">"{t.text}"</p>
              <footer class="testimonial-attr">
                <span class="testimonial-name">{t.name}</span>
                <span class="testimonial-location">{t.location}</span>
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>

    <!-- GALLERY CTA -->
    <section class="gallery-cta">
      <div class="gallery-cta-inner">
        <div class="gallery-cta-number">100+</div>
        <div class="gallery-cta-text">
          <h2 class="gallery-cta-title">Browse Our Previous Work</h2>
          <p class="gallery-cta-sub">Scroll down to see hundreds of completed projects including gates, fences, handrails, custom fabrication, and more.</p>
        </div>
        <div class="gallery-cta-arrow">↓</div>
      </div>
    </section>

    <!-- GALLERY -->
    <section class="gallery" id="gallery">
      <div class="masonry-grid">
        {galleryImages.map((img) => (
          <div class="masonry-item">
            <img src={`/gallery/${img}`} alt="Custom Iron Works project" loading="lazy" />
          </div>
        ))}
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
      <span>© 2026 Custom Iron Works of Oklahoma</span>
      <a href="tel:+14052274404" class="footer-phone">(405) 227-4404</a>
    </footer>

  </body>
</html>