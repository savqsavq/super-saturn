  { title: "Custom Iron Projects", desc: "Designed and built to your exact specifications. No project too unique." },
  { title: "Welding & Metal Fabrication", desc: "Expert welding across all metals. Structural, decorative, and everything between." },
  { title: "Gates & Fences", desc: "Driveway gates, yard fencing, and security barriers built to last decades." },
  { title: "Handrails & Railings", desc: "Interior and exterior handrails crafted for safety and style." },
  { title: "Metal Repair & Restoration", desc: "Bring old iron back to life. We restore, reinforce, and refinish." },
